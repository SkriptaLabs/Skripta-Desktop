{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true
  },
  "types": ["node", "path"],
  "include": ["src/**/*", "../sync_server/index.ts"],
  "exclude": ["node_modules", "dist"]
}
